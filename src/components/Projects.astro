  {
    title: "Mi primer portafolio",
    description: "Un sitio personal creado con Astro y CSS moderno.",
    tech: "Astro • HTML • CSS"
  },
  {
    title: "Landing Page Moderna",
    description: "Diseño limpio con animaciones suaves y responsive.",
    tech: "HTML • CSS • Responsive"
